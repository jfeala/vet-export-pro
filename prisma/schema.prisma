datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  name             String?
  passwordHash     String
  role             String        @default("user")
  onboardedAt      DateTime?
  stripeCustomerId String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  vetProfile       VetProfile?
  invite           Invite?       @relation("InvitedUser")
  clients          Client[]
  certificates     Certificate[]
}

model VetProfile {
  id                          String   @id @default(cuid())
  userId                      String   @unique
  user                        User     @relation(fields: [userId], references: [id])
  hospitalName                String
  hospitalAddress             String
  accreditedVetName           String
  nationalAccreditationNumber String
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model Lead {
  id          String   @id @default(cuid())
  name        String   @default("")
  email       String
  destination String?
  canContact  Boolean?
  createdAt   DateTime @default(now())
  inviteId    String?  @unique
  invite      Invite?  @relation(fields: [inviteId], references: [id])
}

model Invite {
  id         String    @id @default(cuid())
  email      String    @unique
  token      String    @unique @default(cuid())
  invitedAt  DateTime  @default(now())
  acceptedAt DateTime?
  userId     String?   @unique
  user       User?     @relation("InvitedUser", fields: [userId], references: [id])
  lead       Lead?
}

model Client {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  name         String
  phone        String?
  addressUS    String?
  addressEU    String?
  postalCodeEU String?
  phoneEU      String?
  nameEU       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  patients     Patient[]
  certificates Certificate[]
}

model Patient {
  id                   String               @id @default(cuid())
  clientId             String
  client               Client               @relation(fields: [clientId], references: [id])
  species              String
  breed                String?
  name                 String?
  sex                  String?
  color                String?
  dateOfBirth          String?
  identificationNumber String?
  identificationSystem String               @default("Transponder")
  microchipImplantDate String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  certificates         CertificatePatient[]
}

model Certificate {
  id                    String               @id @default(cuid())
  userId                String
  user                  User                 @relation(fields: [userId], references: [id])
  clientId              String?
  client                Client?              @relation(fields: [clientId], references: [id])
  status                String               @default("draft")
  certificateType       String               @default("en-es-2019-1293")
  destinationCountry    String?
  departureDate         String?
  formData              Json                 @default("{}")
  stripePaymentIntentId String?
  chargedAt             DateTime?
  submittedAt           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  patients              CertificatePatient[]
}

model CertificatePatient {
  certificateId String
  certificate   Certificate @relation(fields: [certificateId], references: [id])
  patientId     String
  patient       Patient     @relation(fields: [patientId], references: [id])

  @@id([certificateId, patientId])
}
